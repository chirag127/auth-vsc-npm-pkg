{
  "name": "@chirag127/auth-vsc",
  "version": "0.1.0",
  "description": "VS Code extension auth — vscode.authentication API + Firebase ID-token mint via REST + secure-storage via context.secrets. Peer-deps on @chirag127/auth-core.",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "author": "Chirag Singhal <chirag@oriz.in>",
  "homepage": "https://github.com/chirag127/auth-vsc-npm-pkg#readme",
  "repository": { "type": "git", "url": "git+https://github.com/chirag127/auth-vsc-npm-pkg.git" },
  "bugs": { "url": "https://github.com/chirag127/auth-vsc-npm-pkg/issues" },
  "keywords": ["chirag127", "oriz"],
  "files": ["src", "LICENSE", "README.md"],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": { ".": "./src/index.ts" },
  "publishConfig": { "access": "public" },"peerDependencies":{"@chirag127/auth-core":"^0.1.0"},
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
